{
  "name": "homeclaw",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw plugin for HomeKit smart home control \u2014 lights, locks, thermostats, and scenes",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src/",
    "skills/",
    "agents/",
    "hooks/",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "homekit",
    "smart-home",
    "lights",
    "thermostats",
    "scenes"
  ],
  "author": {
    "name": "Omar Shahine",
    "email": "omar@omarknows.app"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omarshahine/HomeClaw.git",
    "directory": "openclaw"
  },
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.23"
  }
}
